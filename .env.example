# ──────────────────────────────────────────────────────────────
# JESUS CHURCH — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# Supabase — get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Production URL — set this in Vercel environment variables to your live domain.
# Used so Google OAuth redirects back to production, not localhost.
# Example: https://jesusschurch.vercel.app
VITE_SITE_URL="https://your-production-domain.com"
